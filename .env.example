# ── Database (Supabase PostgreSQL) ──
# DATABASE_URL: pooled connection (Transaction mode) - untuk query normal
DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DB?pgbouncer=true"
# DIRECT_URL: direct connection - untuk prisma migrate deploy
DIRECT_URL="postgresql://USER:PASS@HOST:PORT/DB"

# ── NextAuth ──
NEXTAUTH_SECRET="generate-dengan: openssl rand -base64 32"
# Ganti IP_VPS
NEXTAUTH_URL="http://IP_VPS"

# ── Google OAuth ──
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ── Midtrans ──
MIDTRANS_SERVER_KEY="SB-Mid-server-xxx"
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxx"

# ── Vercel Blob Storage ──
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"