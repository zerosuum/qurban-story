// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client-js"
  url = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN
  SUPERADMIN
}

enum OrderStatus {
  PAYMENT_PENDING
  PAID
  FAILED
  EXPIRED
}

enum GroupStatus {
  OPEN
  FULL
  SLAUGHTERED
  COMPLETED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum ReportStage {
  STAGE_1
  STAGE_2
  STAGE_3
}

model User {
  id         String   @id @default(uuid())
  name       String
  email      String   @unique
  provider   String
  providerId String   @map("provider_id")
  role       UserRole  @default(CUSTOMER)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  orders           Order[]
  uploadedDocs     Documentation[]
  reportUpdates    ReportStageLog[]

  @@unique([provider, providerId])
  @@map("users")
}

model AnimalSpecies {
  id              String   @id @default(uuid())
  name            String   @unique
  maxParticipants Int      @map("max_participants")
  createdAt       DateTime @default(now()) @map("created_at")
  products        Product[]

  @@map("animal_species")
}

model Product {
  id          String   @id @default(uuid())
  speciesId   String   @map("species_id")
  name        String
  description String?
  weight      String?
  price       Decimal
  stock       Int
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  species     AnimalSpecies @relation(fields: [speciesId], references: [id], onDelete: Restrict)
  promos      Promo[]
  groups      AnimalGroup[]
  orders      Order[]
  images      ProductImage[]

  @@map("products")
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  imageUrl  String   @map("image_url")
  isPrimary Boolean  @default(false) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model Promo {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  discountType  String?  @map("discount_type")
  discountValue Decimal  @map("discount_value")
  startDate     DateTime @map("start_date")
  endDate       DateTime? @map("end_date")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("promos")
}

model AnimalGroup {
  id          String      @id @default(uuid())
  productId   String      @map("product_id")
  currentSlot Int         @default(0) @map("current_slot")
  maxSlot     Int         @map("max_slot")
  status      GroupStatus
  createdAt   DateTime    @default(now()) @map("created_at")

  product Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  orders  Order[]
  docs    Documentation[]
  reports ReportStageLog[]

  @@map("animal_groups")
}

model Order {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  productId     String      @map("product_id")
  animalGroupId String?     @map("animal_group_id")
  donorName     String      @map("donor_name")
  donorPhone    String      @map("donor_phone")
  totalPrice    Decimal     @map("total_price")
  status        OrderStatus @default(PAYMENT_PENDING)
  snapToken     String?     @map("snap_token")
  createdAt     DateTime    @default(now()) @map("created_at")
  paidAt        DateTime?   @map("paid_at")

  user         User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  product      Product            @relation(fields: [productId], references: [id], onDelete: Restrict)
  group        AnimalGroup?       @relation(fields: [animalGroupId], references: [id], onDelete: Restrict)
  participants OrderParticipant[]
  payment      Payment?
  invoice      Invoice?
  docs         Documentation[]
  reports      ReportStageLog[]

  @@map("orders")
}

model OrderParticipant {
  id              String   @id @default(uuid())
  orderId         String   @map("order_id")
  participantName String   @map("participant_name")
  createdAt       DateTime @default(now()) @map("created_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, participantName])
  @@map("order_participants")
}

model Payment {
  id                    String   @id @default(uuid())
  orderId               String   @unique @map("order_id")
  midtransTransactionId String?  @unique @map("midtrans_transaction_id")
  paymentType           String?  @map("payment_type")
  grossAmount           Decimal? @map("gross_amount")
  transactionStatus     String?  @map("transaction_status")
  rawResponse           Json?    @map("raw_response")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Invoice {
  id            String   @id @default(uuid())
  orderId       String   @unique @map("order_id")
  invoiceNumber String   @unique @map("invoice_number")
  pdfUrl        String?  @map("pdf_url")
  issuedAt      DateTime @default(now()) @map("issued_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Documentation {
  id            String      @id @default(uuid())
  orderId       String?     @map("order_id")
  animalGroupId String?     @map("animal_group_id")
  stage         ReportStage
  mediaType     MediaType   @map("media_type")
  mediaUrl      String      @map("media_url")
  description   String?
  uploadedBy    String?     @map("uploaded_by")
  createdAt     DateTime    @default(now()) @map("created_at")

  order    Order?       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  group    AnimalGroup? @relation(fields: [animalGroupId], references: [id], onDelete: Cascade)
  uploader User?        @relation(fields: [uploadedBy], references: [id], onDelete: SetNull)

  @@map("documentations")
}

model ReportStageLog {
  id            String      @id @default(uuid())
  orderId       String?     @map("order_id")
  animalGroupId String?     @map("animal_group_id")
  stage         ReportStage
  executionDate DateTime?   @map("execution_date")
  updatedBy     String?     @map("updated_by")
  updatedAt     DateTime    @default(now()) @map("updated_at")

  order   Order?       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  group   AnimalGroup? @relation(fields: [animalGroupId], references: [id], onDelete: Cascade)
  updater User?        @relation(fields: [updatedBy], references: [id], onDelete: SetNull)

  @@map("report_stage_logs")
}